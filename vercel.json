{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://xbqsbgyx1v4pfcep.public.blob.vercel-storage.com/sitemap.xml"
    },
    {
      "source": "/google-merchant.xml",
      "destination": "https://xbqsbgyx1v4pfcep.public.blob.vercel-storage.com/google-merchant.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/api/:path*",
      "destination": "https://linea-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/export/admin/generate-feeds",
      "schedule": "0 3 * * *"
    }
  ]
}
